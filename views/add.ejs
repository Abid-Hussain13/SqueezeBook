<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home</title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
</head>

<body class="container">
  <header>
    <div class="mb-3">
      <a class="text-decoration-none heading" style="font-size: 60px;" href="/">SqueezeBook</a>
    </div>
  </header>

  <main class="container">
    <% if (typeof error !=='undefined' ) { %>
      <p class="text-danger">
        <%= error %>
      </p>
      <% } %>
        <form action="/add" method="POST">
          <div class="row">
            <% if (locals.book && locals.book.id) { %>
              <input type="hidden" name="id" value="<%= book.id %>">
              <% } %>
                <div class="col-6 mb-3">
                  <label for="isbn" class="form-label paragraph">ISBN</label>
                  <input type="text" class="form-control" id="isbn" value="<%= book ? book.isbn : '' %>" name="isbn" name="isbn" placeholder="Enter ISBN" required>
                </div>
                <div class="col-6 mb-3">
                  <label for="rating" class="form-label paragraph">My Rating</label>
                  <input type="number" class="form-control" id="rating" name="rating" value="<%= book? book.rating : '' %>"
                    placeholder="Enter Rating" required>
                </div>
                <!-- <div class="col-6 mb-3">
          <label for="author" class="form-label paragraph">Author</label>
          <input type="text" class="form-control" id="author" name="author" placeholder="Author automatically filled" readonly>
        </div>
        <div class="col-12 mb-3">
            <label for="title" class="form-label paragraph">Title</label>
            <input type="text" class="form-control" id="title" name="title" placeholder="Title automatically filled" readonly>
        </div> -->
                <!-- <div class="mb-3 col-12 d-flex justify-content-center">
            <div class="w-25 h-25"><img src="img/courage-to-be-disliked.jpg" class="img-fluid" alt="Image of your book"></div>
        </div> -->
                <div class="mb-3">
                  <label for="summary" class="form-label paragraph">Summary</label>
                  <textarea class="form-control" id="summary" name="summary" rows="4"
                    placeholder="Write Summary about book here"><%= book? book.summary : '' %></textarea>
                </div>
                <div class="mb-3">
                  <label for="notes" class="form-label paragraph">Notes</label>
                  <textarea class="form-control" rows="4" name="notes" id="notes"
                    placeholder="Write your notes here"><%= book? book.notes : '' %></textarea>
                </div>
                <button type="submit" class="btn btn-success mb-5">Submit</button>
          </div>
        </form>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q"
    crossorigin="anonymous"></script>
  <script src="/main.js"></script>
</body>

</html>